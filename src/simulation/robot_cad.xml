  <mujoco model="balance_cad">

    <asset>
      <mesh name="base_link_mesh"
            file="meshes/balancing_robot_combined/base_link.STL"/>
      <mesh name="base_collision_mesh"
            file="meshes/balancing_robot_combined/base_collision_link.STL"/>
      <mesh name="left_wheel_visual_mesh"
            file="meshes/balancing_robot_combined/left_wheel_Link.STL"/>
      <mesh name="right_wheel_visual_mesh"
            file="meshes/balancing_robot_combined/right_wheel_Link.STL"/>
    </asset>

    <worldbody>
      <body name="robot_body" pos = "0 0 0.138">
        <joint name="robot_body_joint" type="free"/>

        <inertial pos="0 0.0 0.057"
                  quat="0.707107 0 0 0.707107"
                  mass="0.514"
                  diaginertia="0.001311 0.0012568 0.000487"/>

        <!-- 기존 collision 유지 -->
        <geom name="base_collision_geom"
              type="mesh"
              mesh="base_collision_mesh"
              rgba = "1 0 0 0.4"/> 

        <geom name="base_visual_geom"
              type="mesh"
              mesh="base_link_mesh"
              contype="0"
              rgba = "0.8 0.8 0.8 0.25"
              conaffinity="0"/> 

        <body name="l_wheel" pos="0 0.026 -0.201">
          <inertial pos="0 0 0"
                    quat="0.5 0.5 -0.5 0.5"
                    mass="0.032"
                    diaginertia="2.3e-05 1.3e-05 1.3e-05"/>
          <joint name="torso_l_wheel"
                type="hinge"
                pos="0 0 0"
                axis="0 -1 0"
                actuatorfrcrange="-5 5"
                damping="0.1"/>
          <geom name="l_wheel_geom"
                pos="0 -0.008 0"
                size="0.037 0.010"
                quat="0.707107 0.707107 0 0"
                type="cylinder"
                rgba="0 1 0 0.6"
                material="wheel_material"/>
          <geom name="l_wheel_visual_geom"
                type="mesh"
                mesh="left_wheel_visual_mesh"
                contype="0"
                rgba = "0.8 0.8 0.8 0.25"
                conaffinity="0"/>
        </body>

        <body name="r_wheel" pos="0 -0.198 -0.201">
          <inertial pos="0 0 0"
                    quat="0.5 0.5 -0.5 0.5"
                    mass="0.032"
                    diaginertia="2.3e-05 1.3e-05 1.3e-05"/>
          <joint name="torso_r_wheel"
                type="hinge"
                pos="0 0 0"
                axis="0 1 0"
                actuatorfrcrange="-5 5"
                damping="0.1"/>
          <geom name="r_wheel_geom"
                pos="0 0.008 0"
                size="0.037 0.010"
                quat="0.707107 0.707107 0 0"
                type="cylinder"
                rgba="0 1 0 0.6"
                material="wheel_material"/>
          <geom name="r_wheel_visual_geom"
                type="mesh"
                mesh="right_wheel_visual_mesh"
                contype="0"
                rgba = "0.8 0.8 0.8 0.25"
                conaffinity="0"/>
        </body>

      </body>
    </worldbody>

    <actuator>
      <velocity name="motor_l_wheel" joint="torso_l_wheel" gear="1" kv="0.9"/>
      <velocity name="motor_r_wheel" joint="torso_r_wheel" gear="1" kv="0.9"/>
    </actuator>

  </mujoco>