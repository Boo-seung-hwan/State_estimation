<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="balance_robot">
    <pose>0 0 0.12 0 0 0</pose>
    <static>false</static>

    <!-- Body -->
    <link name="base_link">
      <pose>0 0 0.08 0 0 0</pose>

      <inertial>
        <mass>0.514</mass>
        <inertia>
          <ixx>0.001311</ixx>
          <iyy>0.0012568</iyy>
          <izz>0.000487</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.10 0.04 0.17</size>
          </box>
        </geometry>
      </collision>

      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.10 0.04 0.17</size>
          </box>
        </geometry>
        <material>
          <diffuse>0.7 0.7 0.7 1</diffuse>
        </material>
      </visual>

      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>200</update_rate>
        <topic>imu</topic>
      </sensor>
    </link>

    <!-- Left wheel -->
    <link name="left_wheel">
      <pose>0 0.074 0.034 1.57079632679 0 0</pose>

      <inertial>
        <mass>0.032</mass>
        <inertia>
          <ixx>0.000023</ixx>
          <iyy>0.000013</iyy>
          <izz>0.000013</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.034</radius>
            <length>0.026</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.034</radius>
            <length>0.026</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Right wheel -->
    <link name="right_wheel">
      <pose>0 -0.074 0.034 1.57079632679 0 0</pose>

      <inertial>
        <mass>0.032</mass>
        <inertia>
          <ixx>0.000023</ixx>
          <iyy>0.000013</iyy>
          <izz>0.000013</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.034</radius>
            <length>0.026</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.034</radius>
            <length>0.026</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Wheel joints -->
    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <pose>0 0.074 0.034 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <pose>0 -0.074 0.034 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <plugin
      filename="ignition-gazebo-joint-state-publisher-system"
      name="ignition::gazebo::systems::JointStatePublisher">
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>

    <plugin
      filename="ignition-gazebo-imu-system"
      name="ignition::gazebo::systems::Imu">
    </plugin>

  </model>
</sdf>
